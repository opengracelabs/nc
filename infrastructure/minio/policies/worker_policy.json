{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WorkerRawReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectAttributes"
      ],
      "Resource": [
        "arn:aws:s3:::nc-raw/*",
        "arn:aws:s3:::nc-normalized/*"
      ]
    },
    {
      "Sid": "WorkerBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::nc-raw",
        "arn:aws:s3:::nc-normalized"
      ]
    },
    {
      "Sid": "WorkerCuratedReadOnly",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::nc-curated",
        "arn:aws:s3:::nc-curated/*"
      ]
    }
  ]
}
