{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "APIReadAll",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectAttributes",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::nc-raw",
        "arn:aws:s3:::nc-raw/*",
        "arn:aws:s3:::nc-normalized",
        "arn:aws:s3:::nc-normalized/*",
        "arn:aws:s3:::nc-curated",
        "arn:aws:s3:::nc-curated/*"
      ]
    },
    {
      "Sid": "APICuratedWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::nc-curated/*"
      ]
    }
  ]
}
