{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://natureandculture.example/standards/nc-ers-v1.schema.json",
  "title": "NC-ERS v1 Edition Registry Standard",
  "type": "object",
  "required": [
    "standard",
    "version",
    "editions"
  ],
  "additionalProperties": false,
  "properties": {
    "standard": {
      "const": "NC-ERS"
    },
    "version": {
      "const": "v1"
    },
    "editions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "registry_id",
          "certificate_id",
          "edition_title",
          "edition_type",
          "format",
          "status",
          "source_identifier"
        ],
        "additionalProperties": false,
        "properties": {
          "registry_id": {
            "type": "string",
            "minLength": 1
          },
          "certificate_id": {
            "type": "string",
            "minLength": 1
          },
          "edition_title": {
            "type": "string",
            "minLength": 1
          },
          "edition_type": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "source_identifier": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
